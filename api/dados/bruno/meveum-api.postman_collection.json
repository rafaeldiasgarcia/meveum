              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/categorias",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "categorias"
              ]
            }
          }
        },
        {
          "name": "Listar Categorias",
          "request": {
            "method": "GET",
            "header": [],
