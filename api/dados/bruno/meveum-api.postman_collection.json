              "raw": "{\n  \"nome\": \"Categoria Teste Bruno Atualizada\",\n  \"descricao\": \"Categoria atualizada manualmente pelo Bruno\",\n  \"ordem\": 3,\n  \"ativo\": true\n}",
              "options": {
