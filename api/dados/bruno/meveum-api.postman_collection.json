          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/categorias/{{categoriaId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "categorias",
                "{{categoriaId}}"
              ]
            }
          }
        }
      ]
    }
